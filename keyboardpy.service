[Unit]
Description=Keyboard Python Script
After=network.target
StartLimitBurst=5
StartLimitIntervalSec=10

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/btpv/dev/keyboardpy/main.py
WorkingDirectory=/home/btpv/dev/keyboardpy
Restart=on-failure
User=btpv
Group=btpv

[Install]
WantedBy=multi-user.target
